{:id :terminal-profiles, :name "Terminal Profiles", :description "Overrides the default profile popover with a terminal aesthetic.", :version "1.0.0", :theme-url nil, :external-scripts [], :ui-form-str "(do\n(defoverride profile-preview-content [{:keys [member]}]\n  [:div {:style {:background \"#000\" :padding \"16px\" :border \"1px solid #333\"}}\n   [:h3 {:style {:color \"#0f0\" :margin 0 :font-family \"monospace\"}}\n    (str \"> \" (:display-name member))]\n   [:p {:style {:color \"#555\" :font-size \"12px\" :font-family \"monospace\"}}\n    (:user-id member)]])\n\n)", :worker-form-str "(do\n(worker/register :plugin-boot\n                 (fn [_]\n                   {:status :success}))\n\n)"}